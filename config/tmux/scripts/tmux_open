#!/usr/bin/env bash
set -euo pipefail

TERMINAL="kitty"

usage() {
    cat <<EOF
Usage: $(basename "$0") -s <session> -m <monitor> -c <command> [-d <dir>]

Options:
  -s, --session   Tmux session name
  -m, --monitor   Monitor name (e.g. DP-1, HDMI-1)
  -c, --command   Command to run inside the tmux session
  -d, --dir       Working directory for the session and terminal (optional)
  -h, --help      Show this help
EOF
    exit 1
}

SESSION=""
MONITOR=""
COMMAND=""
DIR=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -s|--session)  SESSION="$2";  shift 2 ;;
        -m|--monitor)  MONITOR="$2";  shift 2 ;;
        -c|--command)  COMMAND="$2";  shift 2 ;;
        -d|--dir)      DIR="$2";      shift 2 ;;
        -h|--help)     usage ;;
        *) echo "Unknown option: $1"; usage ;;
    esac
done

if [[ -z "$SESSION" || -z "$MONITOR" || -z "$COMMAND" ]]; then
    echo "Error: -s, -m, and -c are required"
    usage
fi

if tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "Session '$SESSION' already exists, attaching to it"
else
    if [[ -n "$DIR" ]]; then
        tmux new-session -d -s "$SESSION" -c "$DIR"
    else
        tmux new-session -d -s "$SESSION"
    fi
    tmux send-keys -t "$SESSION" "$COMMAND" Enter
fi

quote_cmd() {
    printf '%q ' "$@"
}

regex_escape() {
    printf '%s' "$1" | sed -e 's/[][(){}.^$+*?|\\-]/\\&/g'
}

ensure_hypr_env() {
    if [[ -z "${XDG_RUNTIME_DIR:-}" ]]; then
        XDG_RUNTIME_DIR="/run/user/$(id -u)"
        export XDG_RUNTIME_DIR
    fi

    if [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
        return 0
    fi

    local instance_dir
    instance_dir="$(find "$XDG_RUNTIME_DIR/hypr" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort | tail -n1)"
    if [[ -n "$instance_dir" ]]; then
        HYPRLAND_INSTANCE_SIGNATURE="${instance_dir##*/}"
        export HYPRLAND_INSTANCE_SIGNATURE
        return 0
    fi

    return 1
}

hypr_workspace_for_monitor() {
    local monitor="$1"

    if ! command -v jq &>/dev/null; then
        return 1
    fi

    hyprctl monitors -j 2>/dev/null \
        | jq -r --arg monitor "$monitor" '.[] | select(.name == $monitor) | .activeWorkspace.name' \
        | head -n1
}

focus_hypr_window() {
    local title_regex="$1"

    (
        for _ in $(seq 1 20); do
            if hyprctl dispatch focuswindow "title:$title_regex" >/dev/null 2>&1; then
                exit 0
            fi
            sleep 0.1
        done
    ) >/dev/null 2>&1 &
}

focus_sway_window() {
    local title_regex="$1"

    (
        for _ in $(seq 1 20); do
            if swaymsg "[title=\"$title_regex\"] focus" >/dev/null 2>&1; then
                exit 0
            fi
            sleep 0.1
        done
    ) >/dev/null 2>&1 &
}

TERM_ARGS=("$TERMINAL" "--title" "$SESSION")
if [[ -n "$DIR" ]]; then
    TERM_ARGS+=("--directory" "$DIR")
fi
TERM_ARGS+=("tmux" "attach-session" "-t" "$SESSION")
TERM_CMD=$(quote_cmd "${TERM_ARGS[@]}")
TITLE_REGEX="^$(regex_escape "$SESSION")$"

if command -v hyprctl &>/dev/null; then
    if ensure_hypr_env; then
        TARGET_WORKSPACE="$(hypr_workspace_for_monitor "$MONITOR" || true)"
        if [[ -n "$TARGET_WORKSPACE" ]]; then
            hyprctl dispatch exec "[workspace $TARGET_WORKSPACE] $TERM_CMD"
        else
            hyprctl dispatch exec "[monitor:$MONITOR] $TERM_CMD"
        fi
        focus_hypr_window "$TITLE_REGEX"
    else
        echo "Error: could not resolve Hyprland runtime environment" >&2
        exit 1
    fi
elif command -v swaymsg &>/dev/null; then
    swaymsg "focus output $MONITOR, exec $TERM_CMD"
    focus_sway_window "$TITLE_REGEX"
else
    echo "Error: neither Hyprland nor Sway detected"
    exit 1
fi
